# Copy to .env and adjust
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
# In dev, only existing users may log in. Set True to auto-create a user on first OTP login.
OTP_AUTO_CREATE_USER=False

# SMS gateway: 'console' prints code to terminal (no server yet). Swap to a real adapter later.
SMS_BACKEND=console

# Hosts & CORS — on the VPS set your IP/domain here.
# DJANGO_ALLOWED_HOSTS=85.158.145.83,localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=http://85.158.145.83:8000
# Dev: allow any origin (set exact origins in production instead)
CORS_ALLOW_ALL_ORIGINS=True
# Frontend dev origin(s) for CORS (used when CORS_ALLOW_ALL_ORIGINS=False)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
